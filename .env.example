# =========================
# Runtime
# =========================
# dev: local SQLite + startup reset of notification history tables
# prod: PostgreSQL + Alembic-managed schema
ENV=dev

# Database URL
# Intended workflow:
# - local/dev: keep SQLite line enabled
# - production: comment SQLite line, then uncomment PostgreSQL line and update password
DATABASE_URL=sqlite:///./condottiere.db
# DATABASE_URL=postgresql+psycopg://condottiere:UPDATE_ME@127.0.0.1:5432/condottiere


# =========================
# EVE SSO / ESI
# =========================
# Required: update these for your registered EVE app.
EVE_CLIENT_ID=UPDATE_ME
EVE_CLIENT_SECRET=UPDATE_ME
EVE_USER_AGENT=condottiere/1.0 (maintainer: Eadrom Vintarus)

# Local dev:
EVE_REDIRECT_BASE=http://localhost:8000
# Prod:
# EVE_REDIRECT_BASE=https://condottiere.example.com


# =========================
# Security / Admin
# =========================
# Required for production. Use long random strings:
# python -c "import secrets; print(secrets.token_urlsafe(64))"
SESSION_SECRET=dev-session-secret-change-me
CSRF_SECRET=dev-csrf-secret-change-me

# Required for stable token encryption across web/poller/sender processes.
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=UPDATE_ME

# Comma-separated character IDs with admin access.
# Example: ADMIN_CHARACTER_IDS=1234567890,112233445566
ADMIN_CHARACTER_IDS=UPDATE_ME


# =========================
# Sender
# =========================
# Default mention text when sending Discord notifications.
# Examples: @here, @everyone, <@1234567890>, <@&1234567890>, <#1234567890>
DISCORD_DEFAULT_MENTION=

# Minimum seconds between sends to the same destination.
DISCORD_MIN_SECONDS_PER_DESTINATION=1.0

# If no webhook is configured, fallback to in-game EVE mail.
EVE_MAIL_FALLBACK_ENABLED=true
EVE_MAIL_SUBJECT_PREFIX=Condottiere Alert

# Optional test webhook:
# - used by scripts/test_discord_webhook.py
# - used as sender fallback in ENV=dev when no webhook is configured yet
DISCORD_TEST_WEBHOOK_URL=UPDATE_ME
